# Copy to .env and fill in. Never commit the real .env.
DIRECTORY_DOMAIN=directory.example.com
POSTGRES_PASSWORD=
DIRECTORY_PEPPER=

# Twilio Verify (recommended). Leave all three unset and set
# DIRECTORY_ALLOW_DEV_OTP_VENDOR=1 instead only for a non-production trial
# run — it sends nothing and accepts a fixed code.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
DIRECTORY_ALLOW_DEV_OTP_VENDOR=
