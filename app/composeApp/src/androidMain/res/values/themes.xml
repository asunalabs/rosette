<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- DT16: replaces Theme.Material.Light.NoActionBar (which flashed white in
         dark mode). windowBackground is the DayNight @color/window_bg, so the
         cold-launch frame matches ChatTheme. Transparent system bars + edge-to-
         edge (enableEdgeToEdge in MainActivity); Compose insets the content via
         safeDrawingPadding. -->
    <style name="Theme.Chat" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/window_bg</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
    </style>
</resources>
